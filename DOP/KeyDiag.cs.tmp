// TEMP diagnostic — delete after testing
using Terminal.Gui;
Application.Init();
var lbl = new Label { X = 2, Y = 2, Width = 60, Text = "Press any key (Esc to quit)..." };
Application.Top.Add(lbl);
Application.KeyDown += (_, e) =>
{
    lbl.Text = $"KeyCode: {e.KeyCode}  (uint: {(uint)e.KeyCode})";
    if (e.KeyCode == KeyCode.Esc) Application.RequestStop();
};
Application.Run();
Application.Shutdown();
